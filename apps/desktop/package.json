{
  "name": "cabin-desktop",
  "version": "0.1.0",
  "description": "AI-powered code review desktop app for open source maintainers",
  "author": "TarunyaProgrammer <https://github.com/TarunyaProgrammer>",
  "homepage": "https://github.com/TarunyaProgrammer/Cabin-MaintainerOS",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "electron dist/main.js"
  },
  "dependencies": {
    "@cabin/database": "*",
    "@cabin/git": "*",
    "@cabin/github": "*",
    "@cabin/providers": "*",
    "@cabin/review-engine": "*",
    "@cabin/shared": "*",
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "28.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "publish": null,
    "appId": "com.cabin.desktop",
    "productName": "Cabin",
    "electronVersion": "28.2.0",
    "directories": {
      "output": "dist-bin"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      {
        "from": "../../packages/ui/dist",
        "to": "ui/dist"
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb",      "arch": ["x64", "arm64"] },
        { "target": "rpm",      "arch": ["x64"] }
      ],
      "icon": "build/icons",
      "category": "Development"
    }
  }
}
